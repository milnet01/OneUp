<services>
  <!-- Pull the source straight from GitHub and roll a versioned tarball that
       oneup.spec's Source0 expects. Run `osc service manualrun` locally, or let
       OBS run it server-side. -->
  <service name="obs_scm" mode="manual">
    <param name="scm">git</param>
    <param name="url">https://github.com/milnet01/OneUp.git</param>
    <param name="revision">v1.0.1</param>
    <param name="filename">oneup</param>
    <param name="versionformat">1.0.1</param>
  </service>
  <service name="tar" mode="buildtime"/>
  <service name="recompress" mode="buildtime">
    <param name="file">*.tar</param>
    <param name="compression">gz</param>
  </service>
  <service name="set_version" mode="manual"/>
</services>
