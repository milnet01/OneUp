<services>
  <!-- Fetch the source from GitHub and roll the versioned tarball oneup.spec's
       Source0 expects — entirely at BUILD TIME on the OBS servers, so no local
       `osc service manualrun` is needed (upload this file + oneup.spec and build).
       set_version syncs the spec's Version: to the tag, so the tarball and spec
       versions can't drift. -->
  <service name="obs_scm" mode="buildtime">
    <param name="scm">git</param>
    <param name="url">https://github.com/milnet01/OneUp.git</param>
    <param name="revision">v1.0.1</param>
    <param name="filename">oneup</param>
    <param name="versionformat">1.0.1</param>
  </service>
  <service name="tar" mode="buildtime"/>
  <service name="recompress" mode="buildtime">
    <param name="file">*.tar</param>
    <param name="compression">gz</param>
  </service>
  <service name="set_version" mode="buildtime"/>
</services>
