<services>
  <!-- Fetch the source from GitHub and roll the versioned tarball oneup.spec's
       Source0 expects. obs_scm runs SERVER-SIDE (no mode) — the OBS servers have
       network, so they clone the tag and commit a source archive (.obscpio +
       .obsinfo). tar/recompress/set_version then run at BUILD TIME off that archive.
       Trigger it from the web UI with "Trigger Services" (or it runs on _service
       upload); no local `osc service manualrun` is needed. -->
  <service name="obs_scm">
    <param name="scm">git</param>
    <param name="url">https://github.com/milnet01/OneUp.git</param>
    <param name="revision">v1.2.0</param>
    <param name="filename">oneup</param>
    <param name="versionformat">1.2.0</param>
  </service>
  <service name="tar" mode="buildtime"/>
  <service name="recompress" mode="buildtime">
    <param name="file">*.tar</param>
    <param name="compression">gz</param>
  </service>
  <service name="set_version" mode="buildtime"/>
</services>
